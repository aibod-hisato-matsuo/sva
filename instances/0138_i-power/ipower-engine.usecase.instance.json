{
  "document_info": {
    "project_name": "i-Power Engine",
    "version": "0.1.0"
  },
  "usecases": [
    {
      "usecase_id": "uc_001",
      "title": "ユーザーが家庭エネルギー状態を確認する",
      "goal": "PV・蓄電池・買電/売電の現在値と推移を理解する",
      "actors": [
        "user",
        "user_app",
        "cloud",
        "edge_controller",
        "smart_meter",
        "pv_system",
        "battery_system"
      ],
      "preconditions": [
        "HEMS端末が機器と接続済みである",
        "少なくとも1つ以上の計測チャネルが有効である"
      ],
      "main_flow": [
        {
          "step_no": 1,
          "actor": "edge_controller",
          "action": "スマートメーター・PV・蓄電池からデータを収集する",
          "output_data": [
            "grid_import_power",
            "grid_export_power",
            "pv_generation_power",
            "battery_soc"
          ]
        },
        {
          "step_no": 2,
          "actor": "cloud",
          "action": "取得データを正規化・蓄積する",
          "input_data": [
            "grid_import_power",
            "grid_export_power",
            "pv_generation_power",
            "battery_soc"
          ]
        },
        {
          "step_no": 3,
          "actor": "cloud",
          "action": "欠損がある場合は推定値を生成しフラグ付与する",
          "output_data": [
            "estimated_daily_cost",
            "estimated_co2_reduction"
          ]
        },
        {
          "step_no": 4,
          "actor": "user_app",
          "action": "現在値・推移・推定フラグを表示する"
        }
      ],
      "alternative_flows": [
        {
          "condition": "一部データが未取得",
          "flow": [
            "推定値へ切替",
            "最新同期時刻を表示",
            "未取得項目を注記する"
          ]
        }
      ],
      "postconditions": [
        "ユーザーは実測/推定を区別して状態把握できる",
        "データは履歴として参照可能である"
      ],
      "related_layers": [
        "L1",
        "L3",
        "L4",
        "L5"
      ],
      "related_risk_ids": [
        "r_001",
        "r_002"
      ]
    },
    {
      "usecase_id": "uc_002",
      "title": "ユーザーが節約提案を確認し設定する",
      "goal": "契約料金・発電状況・蓄電池状態に応じた推奨を受け取り、モードを選択する",
      "actors": [
        "user",
        "user_app",
        "cloud",
        "external_api",
        "battery_system"
      ],
      "preconditions": [
        "ユーザー契約情報が登録されている",
        "料金関連情報または既知の料金テーブルが利用可能である"
      ],
      "main_flow": [
        {
          "step_no": 1,
          "actor": "cloud",
          "action": "契約料金、消費履歴、発電・蓄電池状態を参照して提案を生成する"
        },
        {
          "step_no": 2,
          "actor": "user_app",
          "action": "提案根拠と予想効果を表示する"
        },
        {
          "step_no": 3,
          "actor": "user",
          "action": "節約優先などのモードを選択する",
          "output_data": [
            "user_policy_mode"
          ]
        },
        {
          "step_no": 4,
          "actor": "cloud",
          "action": "モードを保存し必要に応じて端末へ配信する"
        }
      ],
      "alternative_flows": [
        {
          "condition": "料金APIが取得できない",
          "flow": [
            "直近既知情報で暫定提案を生成",
            "推定扱いを表示する"
          ]
        }
      ],
      "postconditions": [
        "ユーザー方針が保存される",
        "次回以降の提案・制御に反映される"
      ],
      "related_layers": [
        "L0",
        "L1",
        "L2",
        "L3"
      ],
      "related_risk_ids": [
        "r_002",
        "r_004"
      ]
    },
    {
      "usecase_id": "uc_003",
      "title": "停電リスク時に備え優先へ移行する",
      "goal": "停電・災害リスクがある場合に蓄電池残量確保を優先する",
      "actors": [
        "cloud",
        "edge_controller",
        "user_app",
        "battery_system",
        "external_api"
      ],
      "preconditions": [
        "備え優先ポリシーが有効化可能である",
        "蓄電池制御機能が利用可能である"
      ],
      "main_flow": [
        {
          "step_no": 1,
          "actor": "external_api",
          "action": "停電警報または災害情報を提供する",
          "output_data": [
            "outage_alert"
          ]
        },
        {
          "step_no": 2,
          "actor": "cloud",
          "action": "備え優先ルールを評価する",
          "input_data": [
            "outage_alert",
            "battery_soc",
            "user_policy_mode"
          ]
        },
        {
          "step_no": 3,
          "actor": "edge_controller",
          "action": "必要に応じて蓄電池の放電抑制またはSOC下限制御を行う"
        },
        {
          "step_no": 4,
          "actor": "user_app",
          "action": "備え優先への移行と理由を通知する"
        }
      ],
      "alternative_flows": [
        {
          "condition": "クラウド接続なし",
          "flow": [
            "端末の事前設定ルールにより保守動作",
            "復旧後に状態同期する"
          ]
        }
      ],
      "postconditions": [
        "備え優先の運転方針が適用される",
        "ユーザーは変更理由を理解できる"
      ],
      "related_layers": [
        "L0",
        "L2",
        "L3",
        "L4",
        "L5"
      ],
      "related_risk_ids": [
        "r_001",
        "r_005"
      ]
    },
    {
      "usecase_id": "uc_004",
      "title": "通信断時に安全側へ縮退する",
      "goal": "通信断や機器異常が発生しても危険側に倒れない",
      "actors": [
        "edge_controller",
        "cloud",
        "admin_app",
        "user_app"
      ],
      "preconditions": [
        "端末に最低限の保守ルールが設定されている"
      ],
      "main_flow": [
        {
          "step_no": 1,
          "actor": "edge_controller",
          "action": "通信断または機器応答異常を検知する",
          "output_data": [
            "communication_status"
          ]
        },
        {
          "step_no": 2,
          "actor": "edge_controller",
          "action": "安全側縮退ルールを適用する"
        },
        {
          "step_no": 3,
          "actor": "cloud",
          "action": "接続復旧後に差分同期を行う"
        },
        {
          "step_no": 4,
          "actor": "admin_app",
          "action": "障害内容と影響範囲を表示する"
        }
      ],
      "alternative_flows": [
        {
          "condition": "ユーザーアプリ未接続",
          "flow": [
            "管理者向け監視のみ優先",
            "後続同期時に履歴通知する"
          ]
        }
      ],
      "postconditions": [
        "危険な制御は抑止される",
        "障害経緯が記録される"
      ],
      "related_layers": [
        "L3",
        "L4",
        "L5"
      ],
      "related_risk_ids": [
        "r_001",
        "r_003",
        "r_005"
      ]
    }
  ]
}