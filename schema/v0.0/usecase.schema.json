{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/usecase.schema.json",
  "title": "HEMS Usecase Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_info",
    "usecases"
  ],
  "properties": {
    "document_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "version"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "usecases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "usecase_id",
          "title",
          "goal",
          "actors",
          "preconditions",
          "main_flow",
          "postconditions",
          "related_layers"
        ],
        "properties": {
          "usecase_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "actors": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "user",
                "edge_controller",
                "cloud",
                "user_app",
                "admin_app",
                "pv_system",
                "battery_system",
                "smart_meter",
                "external_api"
              ]
            }
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "main_flow": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_no",
                "actor",
                "action"
              ],
              "properties": {
                "step_no": {
                  "type": "integer",
                  "minimum": 1
                },
                "actor": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                },
                "input_data": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "output_data": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "alternative_flows": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "condition",
                "flow"
              ],
              "properties": {
                "condition": {
                  "type": "string"
                },
                "flow": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "postconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "L0",
                "L1",
                "L2",
                "L3",
                "L4",
                "L5"
              ]
            }
          },
          "related_risk_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}