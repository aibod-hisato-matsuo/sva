      "entity_id": "ent_001",
      "name": "measurement_record",
      "category": "measurement",
      "description": "計測値および推定値の共通レコード。",
      "fields": [
        {
          "field_name": "measurement_id",
          "data_type": "string",
          "required": true,
          "description": "計測項目ID",
          "example": "m_004",
          "source_type": "system"
        },
        {
          "field_name": "timestamp",
          "data_type": "datetime",
          "required": true,
          "description": "計測時刻",
          "source_type": "system"
        },
        {
          "field_name": "value",
          "data_type": "number",
          "required": true,
          "description": "値",
          "example": 78.4,
          "source_type": "measured"
        },
        {
          "field_name": "unit",
          "data_type": "string",
          "required": true,
          "description": "単位",
          "example": "%",
          "source_type": "system"
        },
        {
          "field_name": "source_type",
          "data_type": "string",
          "required": true,
          "description": "実測/推定など",
          "enum_values": [
            "measured",
            "estimated",
            "user_input",
            "external_api",
            "derived"
          ],
          "source_type": "system"
        },
        {
          "field_name": "quality_flag",
          "data_type": "string",
          "required": false,
          "description": "品質フラグ",
          "enum_values": [
            "ok",
            "estimated",
            "missing",
            "stale"
          ],
          "source_type": "system"
        }
      ]
    },
