{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/data-model.schema.json",
  "title": "Data Model Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_info",
    "entities"
  ],
  "properties": {
    "document_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "version",
        "language"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "ja",
            "en"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "approved",
            "archived"
          ]
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entity_id",
          "name",
          "category",
          "fields"
        ],
        "properties": {
          "entity_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "measurement",
              "event",
              "command",
              "policy",
              "alert",
              "device_state",
              "sync_status",
              "audit_log",
              "derived_metric"
            ]
          },
          "description": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/fieldDefinition"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "fieldDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_name",
        "data_type",
        "required"
      ],
      "properties": {
        "field_name": {
          "type": "string"
        },
        "data_type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "example": {},
        "enum_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_type": {
          "type": "string",
          "enum": [
            "measured",
            "estimated",
            "user_input",
            "external_api",
            "derived",
            "system"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}