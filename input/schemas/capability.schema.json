{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/capability.schema.json",
  "title": "Capability Model Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_info",
    "capability_groups"
  ],
  "properties": {
    "document_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "version",
        "language"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "ja",
            "en"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "approved",
            "archived"
          ]
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "capability_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "group_id",
          "target_type",
          "name",
          "capabilities"
        ],
        "properties": {
          "group_id": {
            "type": "string"
          },
          "target_type": {
            "type": "string",
            "enum": [
              "pv_system",
              "battery_system",
              "smart_meter",
              "hems_controller",
              "cloud",
              "user_app",
              "admin_app"
            ]
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/capabilityDefinition"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "capabilityDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "name",
        "category",
        "availability"
      ],
      "properties": {
        "capability_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "measurement",
            "control",
            "communication",
            "storage",
            "diagnostics",
            "ota",
            "security",
            "ui",
            "analytics"
          ]
        },
        "availability": {
          "type": "string",
          "enum": [
            "required",
            "preferred",
            "optional",
            "not_supported"
          ]
        },
        "description": {
          "type": "string"
        },
        "related_measurement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_command_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "update_cycle": {
          "type": "string"
        },
        "protocols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_behavior": {
          "type": "string"
        }
      }
    }
  }
}