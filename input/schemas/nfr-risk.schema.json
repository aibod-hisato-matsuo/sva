{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/nfr-risk.schema.json",
  "title": "Non Functional Requirements and Risk Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "non_functional_requirements",
    "risk_register"
  ],
  "properties": {
    "non_functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "nfr_id",
          "category",
          "title",
          "requirement",
          "verification_method"
        ],
        "properties": {
          "nfr_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "performance",
              "availability",
              "security",
              "operability",
              "maintainability",
              "data_quality",
              "ux",
              "ota",
              "auditability"
            ]
          },
          "title": {
            "type": "string"
          },
          "requirement": {
            "type": "string"
          },
          "target_value": {
            "type": "string"
          },
          "verification_method": {
            "type": "string"
          },
          "related_component": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "edge_controller",
                "cloud",
                "user_app",
                "admin_app",
                "network"
              ]
            }
          }
        }
      }
    },
    "risk_register": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "category",
          "title",
          "probability",
          "impact",
          "priority",
          "mitigation",
          "poc_validation"
        ],
        "properties": {
          "risk_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "communication_data_acquisition",
              "data_integrity_quality",
              "ota_firmware",
              "ux_app",
              "security"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "probability": {
            "type": "string",
            "enum": [
              "low",
              "low_medium",
              "medium",
              "medium_high",
              "high"
            ]
          },
          "impact": {
            "type": "string",
            "enum": [
              "medium",
              "high",
              "critical"
            ]
          },
          "priority": {
            "type": "string",
            "pattern": "^[★☆]{5}$"
          },
          "mitigation": {
            "type": "string"
          },
          "poc_validation": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "planned",
              "mitigated",
              "accepted"
            ]
          }
        }
      }
    }
  }
}