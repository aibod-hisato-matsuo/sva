{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/performance-budget.schema.json",
  "title": "Performance Budget Schema",
  "description": "データレート、帯域、バッファ、遅延、再同期などの性能予算を定義するSchema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_info",
    "flows"
  ],
  "properties": {
    "document_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "version",
        "language"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "ja",
            "en"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "approved",
            "archived"
          ]
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/flowDefinition"
      }
    }
  },
  "$defs": {
    "flowDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id",
        "name",
        "related_channel_id",
        "data_type",
        "average_message_size_bytes",
        "peak_message_size_bytes",
        "average_rate_per_sec",
        "peak_rate_per_sec",
        "required_latency_ms",
        "allowable_loss_rate_percent",
        "buffer_size_bytes",
        "local_retention_seconds"
      ],
      "properties": {
        "flow_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "related_channel_id": {
          "type": "string"
        },
        "data_type": {
          "type": "string"
        },
        "average_message_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "peak_message_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "average_rate_per_sec": {
          "type": "number",
          "minimum": 0
        },
        "peak_rate_per_sec": {
          "type": "number",
          "minimum": 0
        },
        "required_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "allowable_loss_rate_percent": {
          "type": "number",
          "minimum": 0
        },
        "buffer_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "local_retention_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "resync_policy": {
          "type": "string"
        },
        "design_notes": {
          "type": "string"
        }
      }
    }
  }
}