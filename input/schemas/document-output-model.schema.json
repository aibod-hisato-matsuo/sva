{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibod.example/schemas/document-output-model.schema.json",
  "title": "Document Output Model Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_info",
    "output_documents"
  ],
  "properties": {
    "document_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "version",
        "language"
      ],
      "properties": {
        "project_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "ja",
            "en"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "approved",
            "archived"
          ]
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "output_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document_id",
          "name",
          "audience",
          "sections"
        ],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/sectionDefinition"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sectionDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "title",
        "source_refs"
      ],
      "properties": {
        "section_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_model",
              "path"
            ],
            "properties": {
              "source_model": {
                "type": "string",
                "enum": [
                  "sva_design",
                  "usecase",
                  "nfr_risk",
                  "capability",
                  "data_model",
                  "document_output_model"
                ]
              },
              "path": {
                "type": "string"
              },
              "transform_rule": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}